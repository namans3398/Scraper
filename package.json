{
  "name": "scraper",
  "version": "1.0.0",
  "description": "Secure desktop video downloader powered by yt-dlp",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc",
    "check": "npm run lint && npm run type-check && npm test",
    "build": "npm run check && electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder -mwl",
    "clean": "rm -rf dist node_modules",
    "reinstall": "npm run clean && npm install",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "youtube",
    "downloader",
    "yt-dlp",
    "scraper",
    "video"
  ],
  "author": "Scraper Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/namans3398/Scraper.git"
  },
  "bugs": {
    "url": "https://github.com/namans3398/Scraper/issues"
  },
  "homepage": "https://github.com/namans3398/Scraper#readme",
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.0",
    "electron": "39.8.10",
    "electron-builder": "26.8.1",
    "eslint": "9.39.1",
    "eslint-plugin-security": "3.0.1",
    "typescript": "5.9.3"
  },
  "build": {
    "appId": "com.scraper.app",
    "productName": "Scraper",
    "copyright": "Copyright © 2026 Scraper Contributors",
    "directories": {
      "output": "dist",
      "buildResources": "Logo"
    },
    "files": [
      "main.js",
      "lib/**/*.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "package.json",
      "!**/*.md",
      "!.github",
      "!.vscode",
      "!dist",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "Logo",
        "to": "Logo",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "Scraper Logo.PNG",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Scraper"
    },
    "linux": {
      "icon": "Scraper Logo.PNG",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "maintainer": "Scraper Contributors",
      "vendor": "Scraper",
      "synopsis": "YouTube Video Downloader",
      "description": "A secure Electron application for downloading YouTube videos using yt-dlp"
    }
  }
}
