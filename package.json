{
  "name": "scraper",
  "version": "1.0.0",
  "description": "Video scraper and downloader using yt-dlp",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "youtube",
    "downloader",
    "yt-dlp",
    "scraper",
    "video"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.1.2",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.yourdomain.scraper",
    "productName": "Scraper",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "styles.css",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
